# 6.9 Favorite Places 

favorite_places = {
    'ernesto': ['china', 'spain'],
    'marcia': ['chicago', 'paris', 'phoenix'],
    'cynthia': ['asheville', 'palestine', 'italy'],
}

for name, places in favorite_places.items():
    print(f"\n{name.title()}'s favorite places are:")
    for place in places:
        print(f"\t{place.title()}")
