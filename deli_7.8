# 7.8 Deli 

sandwich_orders = ['italian sandwich', 'tuna sandwich', 'prime beef rib sandwich', 'teriyaki chicken sandwich', 'veggie sandwich']
finished_sandwiches = []

while sandwich_orders:
    current_sandwich = sandwich_orders.pop()

    print(f"I made your {current_sandwich.title()}!")
    finished_sandwiches.append(current_sandwich)

print("\nEach of the following sandwiches has been made:")
for finished_sandwich in finished_sandwiches:
    print(finished_sandwich.title())
