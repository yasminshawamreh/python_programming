# 7.5 Movie Tickets 

tickets = int(input("How many tickets do you need? "))
total_cost = 0

for i in range(tickets):
    age = int(input("Enter the age of ticket holder: "))

    if age < 3:
        cost = 0
    elif age <= 12:
        cost = 10
    else:
        cost = 15

    total_cost += cost

print(f"\nThe total cost of the tickets is ${total_cost}")
